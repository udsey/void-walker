ENV=local
# LLM Provider Keys (optional - only needed for cloud providers)
# Set model_type in config.yaml: local | groq | gemini | deepseek
GROQ_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# For local (ollama), no API keys needed

# PostgreSQL Database
DB_USER=                     # Database user
DB_PASSWORD=                 # Database password
DB_NAME=                     # Database name
DB_HOST=localhost            # Use 'localhost' for local setup. Docker overrides this.
DB_PORT=5432                 # PostgreSQL default port

# Data Retention
ACTIONS_LIMIT=10000          # Max actions stored in DB. Cron removes oldest sessions when exceeded
LIBRE_API_KEY=               # API key for translation service. Could be randomly generated